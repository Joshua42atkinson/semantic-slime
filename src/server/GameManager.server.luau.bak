--!strict
-- GameManager.server.luau
-- Server authority for "The Local AI Architect"
-- Manages level state, RemoteEvents, and the Ollama bridge (simulated)

local Players        = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService    = game:GetService("HttpService")

local Shared     = ReplicatedStorage:WaitForChild("Shared")
local GameConfig = require(Shared:WaitForChild("GameConfig"))
local QuestData  = require(Shared:WaitForChild("QuestData"))

-- ── RemoteEvent factory ────────────────────────────────────────────────────

local remotes = Instance.new("Folder")
remotes.Name   = "Remotes"
remotes.Parent = ReplicatedStorage

local function makeRemote(name: string, class: string?): RemoteEvent
	local r = Instance.new(class or "RemoteEvent") :: RemoteEvent
	r.Name   = name
	r.Parent = remotes
	return r
end

-- Server → Client
local LevelUpdated   = makeRemote("LevelUpdated")    -- send level info on join/advance
local PeteDialogue   = makeRemote("PeteDialogue")    -- send dialogue lines + mechanic data
local ShowPetePrompt = makeRemote("ShowPetePrompt")  -- show/hide [E] prompt
local WeighGauge     = makeRemote("WeighGauge")      -- send gauge value 0–100
local ForgeResponse  = makeRemote("ForgeResponse")   -- send Build Log (array of strings)
local GameComplete   = makeRemote("GameComplete")    -- all levels done

-- Client → Server
local TalkToPete     = makeRemote("TalkToPete")      -- player pressed E near Pete
local WireConnected  = makeRemote("WireConnected")   -- Level 1: all wires done
local WordEquipped   = makeRemote("WordEquipped")    -- Level 1: VaaM word used on socket
local BuildForged    = makeRemote("BuildForged")     -- Level 2: lesson plan text input
local PromptForged   = makeRemote("PromptForged")    -- Level 3: playtest note submitted

-- ── Per-player state ───────────────────────────────────────────────────────

type PlayerData = {
	levelStage    : number,
	wiresConnected: boolean,
	buildsForged  : boolean,
	promptDone    : boolean,
}

local playerData: {[Player]: PlayerData} = {}

local function getData(player: Player): PlayerData
	if not playerData[player] then
		playerData[player] = {
			levelStage     = 1,
			wiresConnected = false,
			buildsForged   = false,
			promptDone     = false,
		}
	end
	return playerData[player]
end

-- ── Leaderstats ────────────────────────────────────────────────────────────

local function setupLeaderstats(player: Player)
	local ls = Instance.new("Folder")
	ls.Name   = "leaderstats"
	ls.Parent = player

	local levels = Instance.new("IntValue")
	levels.Name   = "Levels"
	levels.Value  = 0
	levels.Parent = ls
end

-- ── Level advancement ──────────────────────────────────────────────────────

local function advanceLevel(player: Player)
	local data  = getData(player)
	local badge = GameConfig.Badges[data.levelStage] or "Unknown"
	print(("[IronNet] %s earned: %s"):format(player.Name, badge))

	data.levelStage     = data.levelStage + 1
	data.wiresConnected = false
	data.buildsForged   = false
	data.promptDone     = false

	local ls = player:FindFirstChild("leaderstats")
	if ls then
		(ls:FindFirstChild("Levels") :: IntValue).Value = data.levelStage - 1
	end

	if data.levelStage > GameConfig.TOTAL_LEVELS then
		GameComplete:FireClient(player, QuestData.CompletionMessage)
		print(("[IronNet] %s completed the game!"):format(player.Name))
	else
		local next = QuestData.Levels[data.levelStage]
		LevelUpdated:FireClient(player, {
			stage     = data.levelStage,
			title     = next.title,
			objective = next.objective,
			total     = GameConfig.TOTAL_LEVELS,
		})
	end
end

-- ── Simulated Forge Log (Level 2) ─────────────────────────────────────────

local DEFAULT_FORGE_LOG = {
	"1. Analyzing Lesson Plan... [OK]",
	"2. Generating Assets... [OK]",
	"3. Scripting Mechanics... [OK]",
	"4. Compiling Game... [OK]",
	"✅  GAME GENERATION COMPLETE. Ready for playtest.",
}

-- ── Player lifecycle ───────────────────────────────────────────────────────

Players.PlayerAdded:Connect(function(player)
	setupLeaderstats(player)
	local data = getData(player)

	player.CharacterAdded:Connect(function()
		task.wait(2) -- let client load
		local level = QuestData.Levels[data.levelStage]
		if level then
			LevelUpdated:FireClient(player, {
				stage     = data.levelStage,
				title     = level.title,
				objective = level.objective,
				total     = GameConfig.TOTAL_LEVELS,
			})
		end
	end)
end)

Players.PlayerRemoving:Connect(function(player)
	playerData[player] = nil
end)

-- ── NPC talk ──────────────────────────────────────────────────────────────

TalkToPete:OnServerEvent:Connect(function(player)
	local data  = getData(player)
	local level = QuestData.Levels[data.levelStage]
	if not level then return end

	PeteDialogue:FireClient(player, {
		lines    = level.npcDialogue,
		stage    = data.levelStage,
		mechanic = level.mechanic,
		-- pass mechanic-specific data the client needs
		wireLabels  = level.wireLabels  or nil,
		vaamSocket  = level.vaamSocket  or nil,
		forgeLog    = level.forgeLog    or nil,
		promptHint  = level.promptHint  or nil,
		promptPlaceholder = level.promptPlaceholder or nil,
	})
end)

-- ── Level 1: Wire puzzle ───────────────────────────────────────────────────

WireConnected:OnServerEvent:Connect(function(player)
	local data = getData(player)
	if data.levelStage ~= 1 or data.wiresConnected then return end
	data.wiresConnected = true
	-- Client will now show VaaM socket — no advance yet, wait for WordEquipped
	print(("[IronNet] %s connected all wires"):format(player.Name))
end)

WordEquipped:OnServerEvent:Connect(function(player, word: string)
	local data  = getData(player)
	local level = QuestData.Levels[data.levelStage]
	if data.levelStage ~= 1 or not data.wiresConnected then return end
	if not level or not level.vaamSocket then return end

	if word == level.vaamSocket.correctWord then
		advanceLevel(player)
	end
	-- Wrong word feedback is handled client-side
end)

-- ── Level 2: Build forge (Lesson Plan Input) ───────────────────────────────

BuildForged:OnServerEvent:Connect(function(player, lessonPlan: string)
	local data  = getData(player)
	local level = QuestData.Levels[data.levelStage]
	if data.levelStage ~= 2 or not level then return end

	if #lessonPlan >= (level.minPromptLength or 20) then
		-- Send simulated build log
		local log = level.forgeLog or DEFAULT_FORGE_LOG
		ForgeResponse:FireClient(player, log)

		data.buildsForged = true
		task.wait(4) -- Wait for client to show log typing effect
		advanceLevel(player)
	end
end)

-- ── Level 3: Playtest note ─────────────────────────────────────────────────

PromptForged:OnServerEvent:Connect(function(player, noteText: string)
	local data  = getData(player)
	local level = QuestData.Levels[data.levelStage]
	if data.levelStage ~= 3 or not level then return end
	if data.promptDone then return end

	if #noteText >= (level.minPromptLength or 20) then
		data.promptDone = true
		-- Send success feedback lines back via PeteDialogue reuse
		PeteDialogue:FireClient(player, {
			lines    = level.successFeedback,
			stage    = 3,
			mechanic = "complete",
		})
		task.wait(4)
		advanceLevel(player)
	end
end)

print("[IronNet] GameManager loaded ✓")
